MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.zosnqpw.mongodb.net/cardly?appName=Cluster0
GEMINI_API_KEY=<gemini-api-key>
GEMINI_CARD_ANALYSIS_MODEL=gemini-2.5-flash-lite
MAX_CARD_IMAGE_BYTES=2097152
PORT=3000

# Firebase Admin (Project settings → Service accounts → Generate new private key)
FIREBASE_PROJECT_ID=<your-firebase-project-id>
FIREBASE_CLIENT_EMAIL=<service-account>@<project>.iam.gserviceaccount.com
# Paste private_key from the JSON; keep \n escapes as a single line
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
